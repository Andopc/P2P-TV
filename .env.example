# ── P2P TV – required variables ───────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Shared secret – all API clients must send: Authorization: Bearer <value>
# Generate a strong token, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
P2PTV_API_KEY=change-me

# Externally reachable URL of the hub (used to build http_url in schedule responses)
P2PTV_BASE_URL=http://localhost:8000

# Path to the data directory inside the container (leave as-is when using docker compose)
P2PTV_DATA_DIR=./data

# Port the hub listens on (host side)
P2PTV_PORT=8000

# ── Node helper ───────────────────────────────────────────────────────────────
P2PTV_HUB_URL=http://hub:8000
P2PTV_CHANNEL_IDS=channel-1,channel-crt
P2PTV_PREFETCH_HOURS=6
P2PTV_CACHE_DIR=./data/torrents
P2PTV_CACHE_MAX_GB=10.0
POLL_INTERVAL_SECONDS=300

# ── qBittorrent ───────────────────────────────────────────────────────────────
QBT_URL=http://qbittorrent:8090
QBT_USERNAME=admin
QBT_PASSWORD=changeme

# ── Docker host user IDs (for linuxserver/qbittorrent) ───────────────────────
PUID=1000
PGID=1000
TZ=Etc/UTC
